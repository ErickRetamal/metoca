# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=appl_xxxxxxxx
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=goog_xxxxxxxx
REVENUECAT_SECRET_API_KEY=sk_xxxxxxxx
REVENUECAT_HOGAR_PRODUCT_IDS=metoca_hogar_monthly
REVENUECAT_FAMILIA_PRODUCT_IDS=metoca_familia_monthly

# Expo / EAS
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
CRON_SECRET=choose-a-long-random-secret

# Firebase (solo para referencia, la config va en google-services.json y GoogleService-Info.plist)
EXPO_PUBLIC_FCM_SENDER_ID=your-sender-id
